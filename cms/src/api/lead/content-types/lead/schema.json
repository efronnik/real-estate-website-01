{
  "kind": "collectionType",
  "collectionName": "leads",
  "info": {
    "singularName": "lead",
    "pluralName": "leads",
    "displayName": "Lead"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "fullName": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email"
    },
    "leadType": {
      "type": "enumeration",
      "enum": [
        "kontakt",
        "inwestor",
        "wycena"
      ],
      "required": true
    },
    "sourcePage": {
      "type": "string",
      "required": true
    },
    "message": {
      "type": "text"
    },
    "city": {
      "type": "string"
    },
    "preferredContactTime": {
      "type": "string"
    },
    "district": {
      "type": "string"
    },
    "propertyType": {
      "type": "enumeration",
      "enum": [
        "mieszkanie",
        "dom",
        "lokal"
      ]
    },
    "areaM2": {
      "type": "decimal"
    },
    "rooms": {
      "type": "integer"
    },
    "condition": {
      "type": "enumeration",
      "enum": [
        "do_remontu",
        "dobry",
        "bardzo_dobry",
        "premium"
      ]
    },
    "floor": {
      "type": "string"
    },
    "buildingType": {
      "type": "string"
    },
    "ownershipType": {
      "type": "string"
    },
    "expectedPrice": {
      "type": "string"
    },
    "timeline": {
      "type": "string"
    },
    "utmSource": {
      "type": "string"
    },
    "utmMedium": {
      "type": "string"
    },
    "utmCampaign": {
      "type": "string"
    },
    "leadStatus": {
      "type": "enumeration",
      "enum": [
        "new",
        "contacted",
        "closed"
      ],
      "default": "new"
    },
    "consentData": {
      "type": "boolean",
      "default": true
    }
  }
}
